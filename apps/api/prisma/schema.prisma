datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// --- Enums ---

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED
  DELETED
}

enum CompanyStatus {
  ACTIVE
  TRIAL
  SUSPENDED
  CANCELLED
}

enum ServiceStatus {
  NEW
  APPOINTMENT_SCHEDULED
  ASSIGNED
  IN_PROGRESS
  WAITING_PART
  WAITING_CUSTOMER_APPROVAL
  REPAIRING
  READY_FOR_DELIVERY
  DELIVERED
  CANCELLED
  UNREACHABLE
  UNPAID
}

enum ServicePriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum ServiceType {
  ON_SITE
  WORKSHOP
  PICKUP
  INSTALLATION
  MAINTENANCE
}

enum PaymentType {
  CASH
  CARD
  BANK_TRANSFER
  OTHER
}

enum PaymentStatus {
  PENDING
  PAID
  PARTIAL
  CANCELLED
  REFUNDED
}

enum FileVisibility {
  PRIVATE
  STAFF_ONLY
  CUSTOMER_VISIBLE
}

// --- Models ---

model Company {
  id            String        @id @default(uuid()) @db.Uuid
  name          String
  slug          String        @unique
  shortCode     String?       @map("short_code")
  phone         String?
  email         String?
  address       String?       @db.Text
  city          String?
  district      String?
  logoFileId    String?       @map("logo_file_id") @db.Uuid
  status        CompanyStatus
  defaultLocale String        @default("tr") @map("default_locale")
  timezone      String        @default("Europe/Istanbul")
  currency      String        @default("TRY")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  deletedAt     DateTime?     @map("deleted_at")

  companyUsers        CompanyUser[]
  roles               Role[]
  customers           Customer[]
  customerAddresses   CustomerAddress[]
  devices             Device[]
  serviceRecords      ServiceRecord[]
  serviceStatusHist   ServiceStatusHistory[]
  serviceNotes        ServiceNote[]
  files               File[]
  servicePhotos       ServicePhoto[]
  serviceAssignments  ServiceAssignment[]
  appointments        Appointment[]
  parts               Part[]
  serviceParts        ServicePart[]
  stockMovements      StockMovement[]
  payments            Payment[]
  expenses            Expense[]
  publicTrackingLinks PublicTrackingLink[]
  auditLogs           AuditLog[]
  notifications       Notification[]

  @@map("companies")
}

model User {
  id           String     @id @default(uuid()) @db.Uuid
  name         String
  email        String     @unique
  phone        String?
  passwordHash String     @map("password_hash")
  avatarFileId String?    @map("avatar_file_id") @db.Uuid
  status       UserStatus
  locale       String     @default("tr")
  lastLoginAt  DateTime?  @map("last_login_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  deletedAt    DateTime?  @map("deleted_at")

  companyUsers CompanyUser[]

  @@map("users")
}

model CompanyUser {
  id        String     @id @default(uuid()) @db.Uuid
  companyId String     @map("company_id") @db.Uuid
  userId    String     @map("user_id") @db.Uuid
  roleId    String     @map("role_id") @db.Uuid
  title     String?
  isOwner   Boolean    @default(false) @map("is_owner")
  status    UserStatus
  invitedAt DateTime?  @map("invited_at")
  joinedAt  DateTime?  @map("joined_at")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  role    Role    @relation(fields: [roleId], references: [id])

  @@unique([companyId, userId])
  @@index([companyId])
  @@index([userId])
  @@index([roleId])
  @@map("company_users")
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  companyId   String?  @map("company_id") @db.Uuid
  name        String
  key         String
  description String?  @db.Text
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  company Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  companyUsers    CompanyUser[]
  rolePermissions RolePermission[]

  @@unique([companyId, key])
  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique
  module      String
  description String?  @db.Text

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String @id @default(uuid()) @db.Uuid
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model Customer {
  id               String    @id @default(uuid()) @db.Uuid
  companyId        String    @map("company_id") @db.Uuid
  fullName         String    @map("full_name")
  phone            String
  secondaryPhone   String?   @map("secondary_phone")
  email            String?
  taxNumber        String?   @map("tax_number")
  taxOffice        String?   @map("tax_office")
  note             String?   @db.Text
  createdByUserId  String    @map("created_by_user_id") @db.Uuid
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  addresses      CustomerAddress[]
  devices        Device[]
  serviceRecords ServiceRecord[]
  payments       Payment[]

  @@index([companyId])
  @@index([companyId, phone])
  @@index([companyId, fullName])
  @@map("customers")
}

model CustomerAddress {
  id           String    @id @default(uuid()) @db.Uuid
  companyId    String    @map("company_id") @db.Uuid
  customerId   String    @map("customer_id") @db.Uuid
  title        String
  city         String?
  district     String?
  neighborhood String?
  addressLine  String    @map("address_line") @db.Text
  locationUrl  String?   @map("location_url") @db.Text
  latitude     Decimal?  @db.Decimal(12, 8)
  longitude    Decimal?  @db.Decimal(12, 8)
  isDefault    Boolean   @default(false) @map("is_default")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  serviceRecords ServiceRecord[]

  @@index([companyId, customerId])
  @@map("customer_addresses")
}

model Device {
  id            String    @id @default(uuid()) @db.Uuid
  companyId     String    @map("company_id") @db.Uuid
  customerId    String    @map("customer_id") @db.Uuid
  category      String
  brand         String?
  model         String?
  serialNo      String?   @map("serial_no")
  purchaseDate  DateTime? @map("purchase_date")
  warrantyUntil DateTime? @map("warranty_until")
  note          String?   @db.Text
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  serviceRecords ServiceRecord[]

  @@index([companyId])
  @@index([companyId, customerId])
  @@index([companyId, serialNo])
  @@map("devices")
}

model ServiceRecord {
  id                  String          @id @default(uuid()) @db.Uuid
  companyId           String          @map("company_id") @db.Uuid
  trackingNo          String          @map("tracking_no")
  customerId          String          @map("customer_id") @db.Uuid
  customerAddressId   String?         @map("customer_address_id") @db.Uuid
  deviceId            String          @map("device_id") @db.Uuid
  serviceType         ServiceType     @map("service_type")
  status              ServiceStatus
  priority            ServicePriority
  faultDescription    String          @map("fault_description") @db.Text
  diagnosis           String?         @db.Text
  internalNote        String?         @map("internal_note") @db.Text
  customerVisibleNote String?         @map("customer_visible_note") @db.Text
  estimatedPrice      Decimal?        @map("estimated_price") @db.Decimal(12, 2)
  approvedPrice       Decimal?        @map("approved_price") @db.Decimal(12, 2)
  totalPaid           Decimal         @default(0) @map("total_paid") @db.Decimal(12, 2)
  currency            String          @default("TRY")
  assignedUserId      String?         @map("assigned_user_id") @db.Uuid
  appointmentAt       DateTime?       @map("appointment_at")
  receivedAt          DateTime?       @map("received_at")
  completedAt         DateTime?       @map("completed_at")
  deliveredAt         DateTime?       @map("delivered_at")
  dueAt               DateTime?       @map("due_at")
  createdByUserId     String          @map("created_by_user_id") @db.Uuid
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")
  deletedAt           DateTime?       @map("deleted_at")

  company         Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer        Customer         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerAddress CustomerAddress? @relation(fields: [customerAddressId], references: [id])
  device          Device           @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  statusHistory       ServiceStatusHistory[]
  notes               ServiceNote[]
  photos              ServicePhoto[]
  assignments         ServiceAssignment[]
  appointments        Appointment[]
  serviceParts        ServicePart[]
  stockMovements      StockMovement[]
  payments            Payment[]
  expenses            Expense[]
  publicTrackingLinks PublicTrackingLink[]

  @@unique([companyId, trackingNo])
  @@index([companyId, status])
  @@index([companyId, customerId])
  @@index([companyId, deviceId])
  @@index([companyId, assignedUserId])
  @@index([companyId, appointmentAt])
  @@index([companyId, dueAt])
  @@map("service_records")
}

model ServiceStatusHistory {
  id              String        @id @default(uuid()) @db.Uuid
  companyId       String        @map("company_id") @db.Uuid
  serviceRecordId String        @map("service_record_id") @db.Uuid
  oldStatus       ServiceStatus? @map("old_status")
  newStatus       ServiceStatus @map("new_status")
  note            String?       @db.Text
  changedByUserId String        @map("changed_by_user_id") @db.Uuid
  createdAt       DateTime      @default(now()) @map("created_at")

  company       Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  serviceRecord ServiceRecord @relation(fields: [serviceRecordId], references: [id], onDelete: Cascade)

  @@index([companyId, serviceRecordId])
  @@index([companyId, createdAt])
  @@map("service_status_history")
}

model ServiceNote {
  id                String    @id @default(uuid()) @db.Uuid
  companyId         String    @map("company_id") @db.Uuid
  serviceRecordId   String    @map("service_record_id") @db.Uuid
  authorUserId      String    @map("author_user_id") @db.Uuid
  body              String    @db.Text
  isCustomerVisible Boolean   @default(false) @map("is_customer_visible")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")

  company       Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  serviceRecord ServiceRecord @relation(fields: [serviceRecordId], references: [id], onDelete: Cascade)

  @@index([companyId, serviceRecordId])
  @@map("service_notes")
}

model File {
  id               String    @id @default(uuid()) @db.Uuid
  companyId        String    @map("company_id") @db.Uuid
  uploadedByUserId String?   @map("uploaded_by_user_id") @db.Uuid
  bucket           String
  objectKey        String    @map("object_key") @db.Text
  originalName     String    @map("original_name")
  mimeType         String    @map("mime_type")
  sizeBytes        BigInt    @map("size_bytes")
  visibility       FileVisibility
  createdAt        DateTime  @default(now()) @map("created_at")
  deletedAt        DateTime? @map("deleted_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  servicePhotos ServicePhoto[]

  @@index([companyId])
  @@index([companyId, uploadedByUserId])
  @@map("files")
}

model ServicePhoto {
  id                String   @id @default(uuid()) @db.Uuid
  companyId         String   @map("company_id") @db.Uuid
  serviceRecordId   String   @map("service_record_id") @db.Uuid
  fileId            String   @map("file_id") @db.Uuid
  title             String?
  description       String?  @db.Text
  isCustomerVisible Boolean  @default(false) @map("is_customer_visible")
  createdAt         DateTime @default(now()) @map("created_at")

  company       Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  serviceRecord ServiceRecord @relation(fields: [serviceRecordId], references: [id], onDelete: Cascade)
  file          File          @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([companyId, serviceRecordId])
  @@map("service_photos")
}

model ServiceAssignment {
  id               String    @id @default(uuid()) @db.Uuid
  companyId        String    @map("company_id") @db.Uuid
  serviceRecordId String    @map("service_record_id") @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  assignedByUserId String    @map("assigned_by_user_id") @db.Uuid
  note             String?   @db.Text
  assignedAt       DateTime  @default(now()) @map("assigned_at")
  unassignedAt     DateTime? @map("unassigned_at")

  company       Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  serviceRecord ServiceRecord @relation(fields: [serviceRecordId], references: [id], onDelete: Cascade)

  @@index([companyId, serviceRecordId])
  @@index([companyId, userId])
  @@map("service_assignments")
}

model Appointment {
  id               String    @id @default(uuid()) @db.Uuid
  companyId        String    @map("company_id") @db.Uuid
  serviceRecordId String    @map("service_record_id") @db.Uuid
  startAt          DateTime  @map("start_at")
  endAt            DateTime? @map("end_at")
  assignedUserId   String?   @map("assigned_user_id") @db.Uuid
  note             String?   @db.Text
  createdByUserId  String    @map("created_by_user_id") @db.Uuid
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  cancelledAt      DateTime? @map("cancelled_at")

  company       Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  serviceRecord ServiceRecord @relation(fields: [serviceRecordId], references: [id], onDelete: Cascade)

  @@index([companyId, startAt])
  @@index([companyId, assignedUserId, startAt])
  @@map("appointments")
}

model Part {
  id            String    @id @default(uuid()) @db.Uuid
  companyId     String    @map("company_id") @db.Uuid
  name          String
  code          String?
  brand         String?
  unit          String    @default("adet")
  purchasePrice Decimal?  @map("purchase_price") @db.Decimal(12, 2)
  salePrice     Decimal?  @map("sale_price") @db.Decimal(12, 2)
  stockQuantity Decimal   @default(0) @map("stock_quantity") @db.Decimal(12, 2)
  currency      String    @default("TRY")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  serviceParts   ServicePart[]
  stockMovements StockMovement[]

  @@unique([companyId, code])
  @@index([companyId])
  @@map("parts")
}

model ServicePart {
  id              String    @id @default(uuid()) @db.Uuid
  companyId       String    @map("company_id") @db.Uuid
  serviceRecordId String    @map("service_record_id") @db.Uuid
  partId          String?   @map("part_id") @db.Uuid
  name            String
  quantity        Decimal   @db.Decimal(12, 2)
  purchasePrice   Decimal?  @map("purchase_price") @db.Decimal(12, 2)
  salePrice       Decimal?  @map("sale_price") @db.Decimal(12, 2)
  currency        String    @default("TRY")
  isRequired      Boolean   @default(false) @map("is_required")
  isSupplied      Boolean   @default(false) @map("is_supplied")
  suppliedAt      DateTime? @map("supplied_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  company       Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  serviceRecord ServiceRecord @relation(fields: [serviceRecordId], references: [id], onDelete: Cascade)
  part          Part?         @relation(fields: [partId], references: [id], onDelete: SetNull)

  @@index([companyId, serviceRecordId])
  @@index([companyId, partId])
  @@map("service_parts")
}

model StockMovement {
  id              String    @id @default(uuid()) @db.Uuid
  companyId       String    @map("company_id") @db.Uuid
  partId          String    @map("part_id") @db.Uuid
  serviceRecordId String?   @map("service_record_id") @db.Uuid
  type            String
  quantity        Decimal   @db.Decimal(12, 2)
  unitCost        Decimal?  @map("unit_cost") @db.Decimal(12, 2)
  note            String?   @db.Text
  createdByUserId String    @map("created_by_user_id") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at")

  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  part          Part           @relation(fields: [partId], references: [id], onDelete: Cascade)
  serviceRecord ServiceRecord? @relation(fields: [serviceRecordId], references: [id], onDelete: SetNull)

  @@index([companyId, partId])
  @@index([companyId, serviceRecordId])
  @@map("stock_movements")
}

model Payment {
  id              String        @id @default(uuid()) @db.Uuid
  companyId       String        @map("company_id") @db.Uuid
  serviceRecordId String?       @map("service_record_id") @db.Uuid
  customerId      String?       @map("customer_id") @db.Uuid
  amount          Decimal       @db.Decimal(12, 2)
  currency        String        @default("TRY")
  paymentType     PaymentType   @map("payment_type")
  status          PaymentStatus
  description     String?       @db.Text
  paidAt          DateTime      @map("paid_at")
  createdByUserId String        @map("created_by_user_id") @db.Uuid
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  deletedAt       DateTime?     @map("deleted_at")

  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  serviceRecord ServiceRecord? @relation(fields: [serviceRecordId], references: [id], onDelete: SetNull)
  customer      Customer?      @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([companyId, paidAt])
  @@index([companyId, serviceRecordId])
  @@index([companyId, customerId])
  @@map("payments")
}

model Expense {
  id              String    @id @default(uuid()) @db.Uuid
  companyId       String    @map("company_id") @db.Uuid
  serviceRecordId String?   @map("service_record_id") @db.Uuid
  category        String
  amount          Decimal   @db.Decimal(12, 2)
  currency        String    @default("TRY")
  description     String?   @db.Text
  spentAt         DateTime  @map("spent_at")
  createdByUserId String    @map("created_by_user_id") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  serviceRecord ServiceRecord? @relation(fields: [serviceRecordId], references: [id], onDelete: SetNull)

  @@index([companyId, spentAt])
  @@index([companyId, serviceRecordId])
  @@map("expenses")
}

model PublicTrackingLink {
  id              String    @id @default(uuid()) @db.Uuid
  companyId       String    @map("company_id") @db.Uuid
  serviceRecordId String    @map("service_record_id") @db.Uuid
  code            String    @unique
  isActive        Boolean   @default(true) @map("is_active")
  expiresAt       DateTime? @map("expires_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  revokedAt       DateTime? @map("revoked_at")

  company       Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  serviceRecord ServiceRecord @relation(fields: [serviceRecordId], references: [id], onDelete: Cascade)

  @@index([companyId, serviceRecordId])
  @@map("public_tracking_links")
}

model AuditLog {
  id           String   @id @default(uuid()) @db.Uuid
  companyId    String?  @map("company_id") @db.Uuid
  actorUserId  String?  @map("actor_user_id") @db.Uuid
  action       String
  entityType   String   @map("entity_type")
  entityId     String?  @map("entity_id") @db.Uuid
  oldValues    Json?    @map("old_values")
  newValues    Json?    @map("new_values")
  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent") @db.Text
  createdAt    DateTime @default(now()) @map("created_at")

  company Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, createdAt])
  @@index([companyId, entityType, entityId])
  @@index([actorUserId, createdAt])
  @@map("audit_logs")
}

model Notification {
  id         String    @id @default(uuid()) @db.Uuid
  companyId  String    @map("company_id") @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  title      String
  body       String?   @db.Text
  type       String
  entityType String?   @map("entity_type")
  entityId   String?   @map("entity_id") @db.Uuid
  readAt     DateTime? @map("read_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, userId])
  @@map("notifications")
}
