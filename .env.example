# PostgreSQL bağlantı adresi (kendi PostgreSQL sunucunuzu yazın)
DATABASE_URL="postgresql://kullanici:sifre@localhost:5432/servis_takip"

# JWT şifreleme anahtarı (en az 32 karakter rastgele metin yazın)
JWT_SECRET="change-this-to-a-random-jwt-secret-key"

# Uygulamanın çalışacağı port (docker için)
PORT=3000

# Uygulama URL'si (CORS ve callback'ler için)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
