# PostgreSQL bağlantı adresi (kendi PostgreSQL sunucunuzu yazın)
DATABASE_URL="postgresql://kullanici:sifre@localhost:5432/servis_takip"

# JWT şifreleme anahtarı (rastgele uzun bir metin yazın)
JWT_SECRET="change-this-to-a-random-secret-key"

# İlk kurulumda oluşturulacak admin hesabı
ADMIN_EMAIL="admin@ornek.com"
ADMIN_PASSWORD="sifre123"
ADMIN_NAME="Admin"
ADMIN_SURNAME="Kullanıcı"

# Şirket bilgileri (ilk kurulum için)
COMPANY_NAME="Benim Servisim"
COMPANY_SLUG="benim-servisim"

# Uygulamanın çalışacağı port (docker için)
PORT=3000

# Uygulama URL'si (CORS ve callback'ler için)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
